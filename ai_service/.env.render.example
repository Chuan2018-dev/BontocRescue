AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=10000

# Render automatically injects PORT.
# The service reads PORT first, then falls back to AI_SERVICE_PORT.

# Optional hosted checkpoint sync.
# Use public or presigned HTTPS URLs from GitHub Releases, R2, S3, or similar.
# If the checkpoint files are already included in the image, these can stay blank.
AI_CHECKPOINT_SYNC_ENABLED=true
AI_CHECKPOINT_SYNC_REQUIRED=false
AI_CHECKPOINT_FORCE_DOWNLOAD=false
AI_CHECKPOINT_DOWNLOAD_TIMEOUT=120
AI_SEVERITY_CHECKPOINT_URL=
AI_SEVERITY_CHECKPOINT_SHA256=
AI_PHOTO_RELEVANCE_CHECKPOINT_URL=
AI_PHOTO_RELEVANCE_CHECKPOINT_SHA256=
