APP_NAME="Stitch Rescue Demo"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-demo-service.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

AI_SEVERITY_ENABLED=false

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=stitch-reverb-app
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=your-demo-service.onrender.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

ROUTING_SERVICE_ENABLED=true
ROUTING_SERVICE_URL=https://router.project-osrm.org
ROUTING_SERVICE_PROFILE=driving
ROUTING_SERVICE_TIMEOUT=8
ROUTING_SERVICE_CACHE_TTL_MINUTES=10
ROUTING_SERVICE_PROVIDER="OSRM Public Routing"
