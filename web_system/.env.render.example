APP_NAME="Stitch Rescue Web"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-stitch-web-service.onrender.com
APP_KEY=base64:generate-this-locally

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=containers-us-west-123.railway.app
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=replace-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sync
CACHE_STORE=file

AI_SEVERITY_ENABLED=true
AI_SEVERITY_SERVICE_HOST=stitch-ai
AI_SEVERITY_SERVICE_PORT=10000
AI_SEVERITY_TIMEOUT=20
AI_SEVERITY_DISPATCH=sync
AI_SEVERITY_MODEL_NAME=bontoc_southern_leyte_production_candidate_external
AI_SEVERITY_MODEL_VERSION=0.2.0

ROUTING_SERVICE_ENABLED=true
ROUTING_SERVICE_URL=https://router.project-osrm.org
ROUTING_SERVICE_PROFILE=driving
ROUTING_SERVICE_TIMEOUT=8
ROUTING_SERVICE_CACHE_TTL_MINUTES=10
ROUTING_SERVICE_PROVIDER="OSRM Public Routing"

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_DEFAULT_REGION=auto
AWS_BUCKET=replace-me
AWS_ENDPOINT=https://replace-me.r2.cloudflarestorage.com
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

REVERB_APP_ID=stitch-reverb-app
REVERB_APP_KEY=replace-me
REVERB_APP_SECRET=replace-me
REVERB_HOST=your-stitch-web-service.onrender.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080
