APP_NAME="Stitch Rescue Web"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=stitch_system
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

AI_SEVERITY_ENABLED=true
AI_SEVERITY_SERVICE_URL=http://127.0.0.1:8100
AI_SEVERITY_SERVICE_HOST=127.0.0.1
AI_SEVERITY_SERVICE_PORT=8100
AI_SEVERITY_TIMEOUT=20
AI_SEVERITY_DISPATCH=sync
AI_SEVERITY_MODEL_NAME=bontoc_southern_leyte_production_candidate_external
AI_SEVERITY_MODEL_VERSION=0.2.0

ROUTING_SERVICE_ENABLED=true
ROUTING_SERVICE_URL=https://router.project-osrm.org
ROUTING_SERVICE_PROFILE=driving
ROUTING_SERVICE_TIMEOUT=8
ROUTING_SERVICE_CACHE_TTL_MINUTES=10
ROUTING_SERVICE_PROVIDER="OSRM Public Routing"

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=stitch-reverb-app
REVERB_APP_KEY=stitch-reverb-key
REVERB_APP_SECRET=stitch-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
